        <calculation class='tableau' formula='AVG(IF [payment_frequency] = &quot;Daily&quot; THEN 4&#10;ELSEIF [payment_frequency] = &quot;Weekly&quot; THEN 3&#10;ELSEIF [payment_frequency] = &quot;Monthly&quot; THEN 2&#10;ELSE 1 END)' />
      </column>
      <column caption='GNH Overall Score' datatype='real' name='[Calculation_0150544718725125]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([q15_crypto_understanding_num]) +&#10;AVG([q13_digital_familiarity_num]) +&#10;AVG([q10_trust_digital]) +&#10;AVG([q19_adopt_crypto_num])) / 4' />
      </column>
      <column caption='Training needed' datatype='integer' name='[Calculation_0594812457701387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF CONTAINS(LOWER([q17_what_helps]), &quot;training&quot;) THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Better Internet' datatype='integer' name='[Calculation_0594812457877516]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF CONTAINS([q17_what_helps], &quot;internet&quot;) THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Goverment Support' datatype='integer' name='[Calculation_0594812458041357]' role='measure' type='quantitative'>
